#!/bin/bash

EXTENSION="$1"

# Loop through all files in the current directory
for file in *.$EXTENSION; do
  # Check if the file name matches the pattern "prefix (number).mp4"
  # or check if the file name matches the pattern "prefix (number) [oMPjtfgv-10].mp4" where  [oMPjtfgv-10] is randomized
  if [[ $file =~ ^(.+)\ \(([0-9]+)\)\.$EXTENSION$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    num="${BASH_REMATCH[2]}"
    # Check if the number is even

    if (( num % 2 == 0 )); then
      rm "$file"
      echo "Deleted $file"
    fi
  # Handle "prefix (number) [random].EXTENSION"
  elif [[ $file =~ ^(.+)\ \(([0-9]+)\)\ \[[^]]+\]\.$EXTENSION$ ]]; then
    prefix="${BASH_REMATCH[1]}"
    num="${BASH_REMATCH[2]}"
    if (( num % 2 == 0 )); then
      rm "$file"
      echo "Deleted $file"
    fi
  fi
done
